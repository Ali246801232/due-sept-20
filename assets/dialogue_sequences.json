	"dialogue_day1_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Anje", "text": "[i]Huff... huff...[/i]"},
				{"speaker": "Ali", "text": "You're here! Lovely.", "audio": "day1_start_1"},
				{"speaker": "Anje", "text": "Whats the emergency?"},
				{"speaker": "Ali", "text": "Yeah, no. Everyone else can't come in right now.", "audio": "day1_start_2"},
				{"speaker": "Ali", "text": "On vacation, sudden heart attack, went missing, finding the one piece, yadayada- Point is.", "audio": "day1_start_3"},
				{"speaker": "Ali", "text": "You gotta fill in for a bit.", "audio": "day1_start_4"},
				{"speaker": "Anje", "text": "How many shifts?"},
				{"speaker": "Ali", "text": "For like... five days...", "audio": "day1_start_5"},
				{"speaker": "Anje", "text": "Huh... that's a lot..."},
				{"speaker": "Ali", "text": "Nahhh, come on!", "audio": "day1_start_6"},
				{"speaker": "Ali", "text": "You know how to bake, right? ...Right?", "audio": "day1_start_7"},
			],
			"next": "cookie_tutorial_choice"
		},
		"cookie_tutorial_choice": {
			"type": "choice",
			"choices": {
				"Uhhhhhh...": "cookie_tutorial_yes",
				"Yessir!": "cookie_tutorial_no"
			}
		},
		"cookie_tutorial_yes": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "(not implemented)"},
			],
			"next": "cookie_tutorial_no"
		},
		"cookie_tutorial_no": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "Peak", "audio": "day1_start_8"},
				{"speaker": "Ali", "text": "Don't worry, I'll check back on you every morning.", "audio": "day1_start_9"},
				{"speaker": "Ali", "text": "But if you screw this up...", "audio": "day1_start_10"},
				{"speaker": "Ali", "text": "I'm gonna cut off your fucking balls.", "audio": "day1_start_11"},
				{"speaker": "Anje", "text": "Awe man..."},
				{"speaker": "Ali", "text": "And your pay, I guess.", "audio": "day1_start_12"},
				{"speaker": "Anje", "text": "OH WHAT."},
				{"speaker": "Ali", "text": "Okay, byebye now!", "audio": "day1_start_13"},
			],
			"next": "end"
		},
	},
	"dialogue_day2_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "Welcome back to the job! Had enough beauty rest?", "audio": "day2_start_1"},
				{"speaker": "Anje", "text": "I didn't get any slepp at all last night..."},
				{"speaker": "Ali", "text": "Too bad. You've got four more days of this ahead of you.", "audio": "day2_start_2"},
				{"speaker": "Anje", "text": "Man..."},
			],
			"next": "end"
		}
	},
	"dialogue_day3_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "Heyyy! How're you holding up?", "audio": "day3_start_1"},
				{"speaker": "Anje", "text": "It's going well so far, I guess."},
				{"speaker": "Ali", "text": "That's what I like to hear!", "audio": "day3_start_2"},
				{"speaker": "Anje", "text": "Just 3 more days... I think I can handle it if nothing weird happens."},
				{"speaker": "Ali", "text": "Keep it up, and I might just make you employee of the month.", "audio": "day3_start_3"},
				{"speaker": "Anje", "text": "Really?"},
				{"speaker": "Ali", "text": "No.", "audio": "day3_start_4"},
			],
			"next": "end"
		}
	},
	"dialogue_day4_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "You're so fucking old... and bald.", "audio": "day4_start_1"},
