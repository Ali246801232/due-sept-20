{
	"dialogue_intro": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Anje", "text": "honk mimimir...", "sprite_override": "Anje Silhoutte"},
				{"speaker": "Anje", "text": "honk mimimimimimimimimimir...", "sprite_override": "Anje Silhoutte"},
				{"speaker": "Anje", "text": "honk mimimimimimimimimimimimimimi-", "sprite_override": "Anje Silhoutte", "autoskip": true},
				{"speaker": "Anje", "text": "[i]*alarms ringing*[/i]", "audio": "intro_alarm", "sprite_override": "Anje Silhoutte"},
				{"speaker": "Anje", "text": "AHHHHHHHHH!"},
				{"speaker": "Anje", "text": "I'M GONNA BE LATE TO MY JOB!!!"},
				{"speaker": "Anje", "text": "AHHHHHH- Wait, hold on..."},
				{"speaker": "Anje", "text": "It's my day off! Phew..."},
				{"speaker": "Anje", "text": "Out of all 365 days today's my one holiday of the year."},
				{"speaker": "Anje", "text": "I've been working my ass off with every odd job I could find..."},
				{"speaker": "Anje", "text": "Back-to-back shifts as a waiter, getting my ass beat as a grade 9 fixer, and now..."},
				{"speaker": "Anje", "text": "A cookie tester."},
				{"speaker": "Anje", "text": "Now that I've got some time off, maybe I should hop back on League."},
				{"speaker": "Anje", "text": "[i]*phone rings*[/i]", "audio": "intro_ringing_phone"},
				{"speaker": "Anje", "text": "Gah. Who the hell..."},
				{"speaker": "Anje", "text": "My bakery boss???"},
				{"speaker": "Anje", "text": "[i]*picks up phone*[/i]", "audio": "intro_pick_up_phone"},
				{"speaker": "Ali", "text": "Oi.", "audio": "intro_1"},
				{"speaker": "Ali", "text": "Get your ass over here.", "audio": "intro_2"},
				{"speaker": "Anje", "text": "Wha- ...ok???"},
			],
			"next": "end"
		}
	},

