		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Kraze", "text": "What type of dogshit bakery doesn't even have apple fritters??", "audio": "success_kraze_1"},
				{"speaker": "Anje", "text": "W-well, at least... try the cookies..."},
				{"speaker": "Kraze", "text": "[i]*eats*[/i] - Mm... Eh... Eugh, this tastes like shit.", "audio": "success_kraze_2"},
				{"speaker": "Anje", "text": "Awe..."},
			],
			"next": "end"
		},
	},
