	"dialogue_day5_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "Last day! You've made it so far.", "audio": "day5_start_1"},
				{"speaker": "Ali", "text": "Just one more and you'll be back to being a good ol' cookie tester.", "audio": "day5_start_2"},
				{"speaker": "Ali", "text": "...Whatever the fuck that is.", "audio": "day5_start_3"},
				{"speaker": "Anje", "text": "Can't wait..."},
				{"speaker": "Ali", "text": "By the way, recipe screen should be fixed now.", "audio": "day5_start_4"},
				{"speaker": "Ali", "text": "Mk, that's all!", "audio": "day5_start_5"},
				{"speaker": "Ali", "text": "Byebye!", "audio": "day5_start_6"},
			],
			"next": "end"
		}
	},
	"dialogue_day6_start": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Ali", "text": "Great work on your shifts! I'll pay you double, fr.", "audio": "day6_start_1"},
				{"speaker": "Anje", "text": "That was wayyy more than double my usual work..."},
				{"speaker": "Ali", "text": "Well... Just one more order.", "audio": "day6_start_2"},
				{"speaker": "Anje", "text": "Stil???"},
				{"speaker": "Ali", "text": "It's a special order for a cake!", "audio": "day6_start_3"},
				{"speaker": "Anje", "text": "I can't bake no more, man."},
				{"speaker": "Ali", "text": "Don't worry, it's already done! You just gotta deliver it.", "audio": "day6_start_4"},
				{"speaker": "Anje", "text": "Alright... Get this over with finally..."},
			],
			"next": "end"
		}
	},

	"dialogue_take_order_kraze": {
		"start": {"type": "start", "next": "lines"},
		"end": {"type": "end"},
		"lines": {
			"type": "conversation",
			"lines": [
				{"speaker": "Kraze", "text": "[i]*cough*[/i] - Yoo big dawg, I need me an apple fritter, you- you feel me?", "audio": "take_order_kraze_1"},
				{"speaker": "Anje", "text": "An apple... what now?"},
				{"speaker": "Anje", "text": "I don't think we have those."},
				{"speaker": "Kraze", "text": "..."},
				{"speaker": "Kraze", "text": "Come again?", "audio": "take_order_kraze_2"},
				{"speaker": "Anje", "text": "We don't have any fritters-", "autoskip": true},
				{"speaker": "Kraze", "text": "WHAT THE [b]FUCK[/b]. DO YOU [i]MEAN[/i]. NO APPLE FRITTERS?!", "audio": "take_order_kraze_3"},
				{"speaker": "Anje", "text": "Uhhhhhh-"},
				{"speaker": "Anje", "text": "We uh- we got cheese cookies, chocolate chip cookies, cookies cookies-"},
				{"speaker": "Kraze", "text": "[i]*sigh*[/i] - Fine. Sugar Cookies.", "audio": "take_order_kraze_4"},
				{"speaker": "Kraze", "text": "But you only have 30 seconds.", "audio": "take_order_kraze_5"},
			],
			"next": "end"
		},
	},
